FROM python:3.12-slim

# Create non-root user
RUN useradd --create-home appuser

WORKDIR /app

# Install system deps + uv
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Switch to non-root user before installing deps (avoids chown on large .venv)
RUN chown appuser:appuser /app
USER appuser

# Install Python deps
# TORCH_INDEX: use cu118 for older GPUs (Pascal, Turing, Ampere)
#              use nightly/cu128 for Blackwell (RTX 50 series)
ARG TORCH_INDEX=cu118
RUN uv venv && \
    uv pip install \
        $(echo "${TORCH_INDEX}" | grep -q nightly && echo "--prerelease=allow") \
        "torch>=2.0" \
        --index-url https://download.pytorch.org/whl/${TORCH_INDEX} && \
    uv pip install \
        "requests>=2.31" \
        "langchain-text-splitters>=0.2" \
        "tqdm>=4.66" \
        "sentence-transformers>=3.0"

# Pre-download pinned model weights into the image
RUN .venv/bin/python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('BAAI/bge-large-en-v1.5', revision='d4aa6901d3a41ba39fb536a557fa166f842b0e09')"

# No HuggingFace network calls at runtime
ENV HF_HUB_OFFLINE=1

# Copy app code (only what's needed)
COPY --chown=appuser:appuser server/models/bge.py server/models/bge.py
COPY --chown=appuser:appuser server/__init__.py server/__init__.py
COPY --chown=appuser:appuser server/models/__init__.py server/models/__init__.py
COPY --chown=appuser:appuser client/chunk.py client/chunk.py
COPY --chown=appuser:appuser client/ingest_chunks.py client/ingest_chunks.py
COPY --chown=appuser:appuser client/__init__.py client/__init__.py

ENTRYPOINT [".venv/bin/python", "-m", "client.ingest_chunks"]
